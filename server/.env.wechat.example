# ============================================
# 微信小程序配置文件模板
# 复制此文件为 .env.production 并填写实际值
# ============================================

# --------------------------------------------
# 微信小程序配置
# --------------------------------------------
# 获取方式：微信公众平台 → 开发 → 开发设置
WECHAT_APP_ID=wx0000000000000000
WECHAT_APP_SECRET=00000000000000000000000000000000

# --------------------------------------------
# 服务器域名配置
# --------------------------------------------
# 开发环境：http://localhost:3000
# 生产环境：https://your-domain.com
PROJECT_DOMAIN=https://your-domain.com

# --------------------------------------------
# 微信支付配置（可选）
# --------------------------------------------
# 获取方式：微信支付商户平台 → 账户中心 → API安全
WECHAT_MCH_ID=0000000000
WECHAT_API_KEY=00000000000000000000000000000000

# --------------------------------------------
# 数据库配置（Supabase）
# --------------------------------------------
# 获取方式：Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --------------------------------------------
# Redis 缓存配置
# --------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --------------------------------------------
# Elasticsearch 配置（可选）
# --------------------------------------------
ES_NODE=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=

# --------------------------------------------
# 阿里云短信配置（可选）
# --------------------------------------------
# 获取方式：阿里云控制台 → AccessKey管理
ALIYUN_SMS_ACCESS_KEY_ID=LTAI5t...
ALIYUN_SMS_ACCESS_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --------------------------------------------
# JWT 认证配置
# --------------------------------------------
# JWT 密钥（建议使用随机生成的密钥）
# 生成方式：openssl rand -base64 32
JWT_SECRET=your-secret-key-here
# Token 有效期（如：7d = 7天，1h = 1小时）
JWT_EXPIRES_IN=7d

# --------------------------------------------
# Node 运行环境
# --------------------------------------------
NODE_ENV=production
PORT=3000

# --------------------------------------------
# 日志配置
# --------------------------------------------
LOG_LEVEL=info

# --------------------------------------------
# 限制配置
# --------------------------------------------
# 最大文件上传大小（字节）
MAX_FILE_SIZE=10485760
# 请求频率限制（每分钟）
RATE_LIMIT_MAX=60
