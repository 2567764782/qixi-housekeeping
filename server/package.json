{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS server application",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint src/ --ext .ts --fix",
    "lint:build": "eslint src/ --ext .ts && tsc --noEmit",
    "deploy": "s deploy -y",
    "deploy:prod": "s deploy --stage prod -y",
    "deploy:remove": "s remove -y",
    "logs": "s logs",
    "metrics": "s metrics",
    "elk:start": "./start-elk.sh",
    "elk:stop": "./stop-elk.sh",
    "elk:logs": "docker-compose logs -f",
    "monitoring:start": "./start-monitoring.sh",
    "monitoring:stop": "./stop-monitoring.sh",
    "jaeger:start": "./start-jaeger.sh",
    "jaeger:stop": "./stop-jaeger.sh",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@alicloud/dysmsapi20170525": "^4.5.0",
    "@alicloud/openapi-client": "^0.4.15",
    "@aws-sdk/client-s3": "^3.958.0",
    "@aws-sdk/lib-storage": "^3.958.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/websockets": "^11.1.16",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@supabase/supabase-js": "2.95.3",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "axios": "^1.7.9",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.9.1",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "coze-coding-dev-sdk": "^0.7.16",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "5.2.1",
    "ioredis": "^5.10.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "prom-client": "^15.1.3",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-elasticsearch": "^0.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^11.1.16",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@serverless-devs/s": "^3.1.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.2"
  }
}
